{
  "$schema": "https://tr.designtokens.org/format/schema.json",
  "metadata": {
    "name": "IntegrateWise Design Tokens",
    "version": "1.0.0",
    "description": "Complete design system tokens for IntegrateWise - The Knowledge Workspace",
    "lastUpdated": "2026-03-21"
  },
  "colors": {
    "brand": {
      "primary": {
        "$type": "color",
        "$value": "#3F5185",
        "$description": "Primary navy blue - Main brand color from Guidelines"
      },
      "primary-light": {
        "$type": "color",
        "$value": "#4256AB",
        "$description": "Logo-derived primary blue"
      },
      "primary-deep": {
        "$type": "color",
        "$value": "#4152A1",
        "$description": "Deep blue from logo spine path"
      },
      "primary-dark": {
        "$type": "color",
        "$value": "#354890",
        "$description": "Darker variant for hover states"
      },
      "accent": {
        "$type": "color",
        "$value": "#F54476",
        "$description": "Accent pink/magenta from Guidelines"
      },
      "accent-hover": {
        "$type": "color",
        "$value": "#EE4B75",
        "$description": "Logo dot pink - CTAs & highlights"
      },
      "accent-dark": {
        "$type": "color",
        "$value": "#D93D65",
        "$description": "Darker pink for active states"
      }
    },
    "semantic": {
      "success": {
        "$type": "color",
        "$value": "#00C853",
        "$description": "Emerald green for success states"
      },
      "success-alt": {
        "$type": "color",
        "$value": "#3D8B6E",
        "$description": "Alternative success (chart-2)"
      },
      "warning": {
        "$type": "color",
        "$value": "#FF9800",
        "$description": "Amber orange for warnings"
      },
      "warning-alt": {
        "$type": "color",
        "$value": "#D4883E",
        "$description": "Alternative warning (chart-3)"
      },
      "danger": {
        "$type": "color",
        "$value": "#F54476",
        "$description": "Pink for errors/danger (same as accent)"
      },
      "danger-alt": {
        "$type": "color",
        "$value": "#DC4A4A",
        "$description": "Alternative danger/destructive"
      },
      "info": {
        "$type": "color",
        "$value": "#7B9BFF",
        "$description": "Blue for informational states"
      }
    },
    "flow": {
      "a": {
        "$type": "color",
        "$value": "#3F5185",
        "$description": "Flow A - Structured Data (Blue)"
      },
      "b": {
        "$type": "color",
        "$value": "#7B5EA7",
        "$description": "Flow B - Unstructured Data (Purple)"
      },
      "c": {
        "$type": "color",
        "$value": "#00C853",
        "$description": "Flow C - AI Chats (Emerald)"
      }
    },
    "intelligence": {
      "spine": {
        "$type": "color",
        "$value": "#5FA8D3",
        "$description": "Spine/SSOT indicator color"
      },
      "hub": {
        "$type": "color",
        "$value": "#9B6DC6",
        "$description": "Intelligence Hub accent"
      },
      "agent": {
        "$type": "color",
        "$value": "#6BC77A",
        "$description": "AI Twin/Agent indicator"
      },
      "overlay-bg": {
        "$type": "color",
        "$value": "rgba(16, 42, 67, 0.94)",
        "$description": "Intelligence overlay background"
      },
      "overlay-surface": {
        "$type": "color",
        "$value": "#1A2E42",
        "$description": "Intelligence overlay surface"
      }
    },
    "neutrals": {
      "50": {
        "$type": "color",
        "$value": "#F5F6FA",
        "$description": "Lightest background"
      },
      "100": {
        "$type": "color",
        "$value": "#EDF0F5",
        "$description": "Secondary/muted backgrounds"
      },
      "200": {
        "$type": "color",
        "$value": "#DDE3EC",
        "$description": "Accent backgrounds"
      },
      "300": {
        "$type": "color",
        "$value": "#D8DEE8",
        "$description": "Borders"
      },
      "400": {
        "$type": "color",
        "$value": "#B0B8C5",
        "$description": "Switch backgrounds, disabled states"
      },
      "500": {
        "$type": "color",
        "$value": "#64748B",
        "$description": "Muted foreground text"
      },
      "600": {
        "$type": "color",
        "$value": "#475569",
        "$description": "Secondary text"
      },
      "700": {
        "$type": "color",
        "$value": "#334155",
        "$description": "Tertiary text"
      },
      "800": {
        "$type": "color",
        "$value": "#1E293B",
        "$description": "Primary foreground/text"
      },
      "900": {
        "$type": "color",
        "$value": "#102A43",
        "$description": "Darkest blue-gray"
      },
      "white": {
        "$type": "color",
        "$value": "#FFFFFF",
        "$description": "Pure white"
      }
    },
    "charts": {
      "1": {
        "$type": "color",
        "$value": "#4256AB",
        "$description": "Chart color 1 - Primary blue"
      },
      "2": {
        "$type": "color",
        "$value": "#3D8B6E",
        "$description": "Chart color 2 - Success green"
      },
      "3": {
        "$type": "color",
        "$value": "#D4883E",
        "$description": "Chart color 3 - Warning orange"
      },
      "4": {
        "$type": "color",
        "$value": "#7B5EA7",
        "$description": "Chart color 4 - Purple"
      },
      "5": {
        "$type": "color",
        "$value": "#EE4B75",
        "$description": "Chart color 5 - Accent pink"
      }
    }
  },
  "typography": {
    "fontFamilies": {
      "sans": {
        "$type": "fontFamily",
        "$value": "'Inter', system-ui, sans-serif",
        "$description": "Primary sans-serif font family"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": "'JetBrains Mono', monospace",
        "$description": "Monospace font for code"
      }
    },
    "fontSizes": {
      "xs": {
        "$type": "dimension",
        "$value": "0.75rem",
        "$description": "12px - Extra small text"
      },
      "sm": {
        "$type": "dimension",
        "$value": "0.875rem",
        "$description": "14px - Small text"
      },
      "base": {
        "$type": "dimension",
        "$value": "1rem",
        "$description": "14px - Base font size (root is 14px)"
      },
      "lg": {
        "$type": "dimension",
        "$value": "1.125rem",
        "$description": "~16px - Large text"
      },
      "xl": {
        "$type": "dimension",
        "$value": "1.25rem",
        "$description": "~18px - Extra large"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "1.5rem",
        "$description": "~21px - Heading 1"
      },
      "3xl": {
        "$type": "dimension",
        "$value": "1.875rem",
        "$description": "~26px - Large heading"
      },
      "4xl": {
        "$type": "dimension",
        "$value": "2.25rem",
        "$description": "~32px - Hero text"
      }
    },
    "fontWeights": {
      "light": {
        "$type": "number",
        "$value": 300,
        "$description": "Light weight"
      },
      "normal": {
        "$type": "number",
        "$value": 400,
        "$description": "Normal/regular weight"
      },
      "medium": {
        "$type": "number",
        "$value": 500,
        "$description": "Medium weight (default for headings/buttons)"
      },
      "semibold": {
        "$type": "number",
        "$value": 600,
        "$description": "Semibold weight"
      },
      "bold": {
        "$type": "number",
        "$value": 700,
        "$description": "Bold weight"
      },
      "extrabold": {
        "$type": "number",
        "$value": 800,
        "$description": "Extra bold weight"
      }
    },
    "lineHeights": {
      "tight": {
        "$type": "number",
        "$value": 1.25,
        "$description": "Tight line height"
      },
      "normal": {
        "$type": "number",
        "$value": 1.5,
        "$description": "Normal line height (default)"
      },
      "relaxed": {
        "$type": "number",
        "$value": 1.75,
        "$description": "Relaxed line height"
      },
      "loose": {
        "$type": "number",
        "$value": 2,
        "$description": "Loose line height"
      }
    },
    "letterSpacing": {
      "tighter": {
        "$type": "dimension",
        "$value": "-0.05em",
        "$description": "Tighter tracking"
      },
      "tight": {
        "$type": "dimension",
        "$value": "-0.025em",
        "$description": "Tight tracking"
      },
      "normal": {
        "$type": "dimension",
        "$value": "0em",
        "$description": "Normal tracking"
      },
      "wide": {
        "$type": "dimension",
        "$value": "0.025em",
        "$description": "Wide tracking"
      },
      "wider": {
        "$type": "dimension",
        "$value": "0.05em",
        "$description": "Wider tracking"
      },
      "widest": {
        "$type": "dimension",
        "$value": "0.1em",
        "$description": "Widest tracking (uppercase labels)"
      }
    }
  },
  "spacing": {
    "0": {
      "$type": "dimension",
      "$value": "0rem",
      "$description": "0px"
    },
    "1": {
      "$type": "dimension",
      "$value": "0.25rem",
      "$description": "4px - Base spacing unit"
    },
    "2": {
      "$type": "dimension",
      "$value": "0.5rem",
      "$description": "8px"
    },
    "3": {
      "$type": "dimension",
      "$value": "0.75rem",
      "$description": "12px"
    },
    "4": {
      "$type": "dimension",
      "$value": "1rem",
      "$description": "16px - Standard spacing"
    },
    "5": {
      "$type": "dimension",
      "$value": "1.25rem",
      "$description": "20px"
    },
    "6": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "24px"
    },
    "8": {
      "$type": "dimension",
      "$value": "2rem",
      "$description": "32px"
    },
    "10": {
      "$type": "dimension",
      "$value": "2.5rem",
      "$description": "40px"
    },
    "12": {
      "$type": "dimension",
      "$value": "3rem",
      "$description": "48px"
    },
    "16": {
      "$type": "dimension",
      "$value": "4rem",
      "$description": "64px"
    },
    "20": {
      "$type": "dimension",
      "$value": "5rem",
      "$description": "80px"
    },
    "24": {
      "$type": "dimension",
      "$value": "6rem",
      "$description": "96px"
    }
  },
  "borderRadius": {
    "none": {
      "$type": "dimension",
      "$value": "0rem",
      "$description": "No radius"
    },
    "sm": {
      "$type": "dimension",
      "$value": "0.125rem",
      "$description": "2px - Small radius"
    },
    "md": {
      "$type": "dimension",
      "$value": "0.25rem",
      "$description": "4px - Medium radius"
    },
    "base": {
      "$type": "dimension",
      "$value": "0.5rem",
      "$description": "8px - Base radius"
    },
    "lg": {
      "$type": "dimension",
      "$value": "0.75rem",
      "$description": "12px - Large radius"
    },
    "xl": {
      "$type": "dimension",
      "$value": "1rem",
      "$description": "16px - Extra large radius"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "1.5rem",
      "$description": "24px - 2XL radius (cards)"
    },
    "3xl": {
      "$type": "dimension",
      "$value": "2rem",
      "$description": "32px - 3XL radius (onboarding)"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px",
      "$description": "Fully rounded (pills, badges)"
    }
  },
  "shadows": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.05)"
      },
      "$description": "Small shadow"
    },
    "base": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "3px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$description": "Base shadow"
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "-1px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$description": "Medium shadow"
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "10px",
        "blur": "15px",
        "spread": "-3px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$description": "Large shadow"
    },
    "xl": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "20px",
        "blur": "25px",
        "spread": "-5px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$description": "Extra large shadow"
    },
    "2xl": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "25px",
        "blur": "50px",
        "spread": "-12px",
        "color": "rgba(0, 0, 0, 0.25)"
      },
      "$description": "2XL shadow (modals, overlays)"
    }
  },
  "transitions": {
    "duration": {
      "fast": {
        "$type": "duration",
        "$value": "150ms",
        "$description": "Fast transition"
      },
      "base": {
        "$type": "duration",
        "$value": "200ms",
        "$description": "Base transition"
      },
      "slow": {
        "$type": "duration",
        "$value": "300ms",
        "$description": "Slow transition"
      },
      "slower": {
        "$type": "duration",
        "$value": "500ms",
        "$description": "Slower transition"
      }
    },
    "easing": {
      "linear": {
        "$type": "cubicBezier",
        "$value": [0, 0, 1, 1],
        "$description": "Linear easing"
      },
      "ease": {
        "$type": "cubicBezier",
        "$value": [0.25, 0.1, 0.25, 1],
        "$description": "Default ease"
      },
      "easeIn": {
        "$type": "cubicBezier",
        "$value": [0.4, 0, 1, 1],
        "$description": "Ease in"
      },
      "easeOut": {
        "$type": "cubicBezier",
        "$value": [0, 0, 0.2, 1],
        "$description": "Ease out (recommended)"
      },
      "easeInOut": {
        "$type": "cubicBezier",
        "$value": [0.4, 0, 0.2, 1],
        "$description": "Ease in-out"
      }
    }
  },
  "breakpoints": {
    "sm": {
      "$type": "dimension",
      "$value": "640px",
      "$description": "Small devices (mobile landscape)"
    },
    "md": {
      "$type": "dimension",
      "$value": "768px",
      "$description": "Medium devices (tablets)"
    },
    "lg": {
      "$type": "dimension",
      "$value": "1024px",
      "$description": "Large devices (laptops)"
    },
    "xl": {
      "$type": "dimension",
      "$value": "1280px",
      "$description": "Extra large devices (desktops)"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "1536px",
      "$description": "2XL devices (large desktops)"
    }
  },
  "zIndex": {
    "base": {
      "$type": "number",
      "$value": 0,
      "$description": "Base layer"
    },
    "dropdown": {
      "$type": "number",
      "$value": 10,
      "$description": "Dropdowns, popovers"
    },
    "sticky": {
      "$type": "number",
      "$value": 20,
      "$description": "Sticky headers"
    },
    "fixed": {
      "$type": "number",
      "$value": 30,
      "$description": "Fixed elements"
    },
    "overlay": {
      "$type": "number",
      "$value": 40,
      "$description": "Overlays, backdrops"
    },
    "modal": {
      "$type": "number",
      "$value": 50,
      "$description": "Modals, dialogs"
    },
    "toast": {
      "$type": "number",
      "$value": 60,
      "$description": "Toasts, notifications"
    }
  }
}
